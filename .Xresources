! Appearance
URxvt*termName: rxvt-unicode
URxvt*scrollBar: false
URxvt*iconFile: /usr/share/icons/matefaenza/apps/scalable/terminal.svg
URxvt*colorUL: #8ae234
URxvt*underlineColor: #8ae234
! URxvt*cursorColor:        #8ae234

! URxvt*background: black
URxvt*depth: 32
URxvt*background: rgba:2e2e/3434/3636/f500
URxvt*foreground: rgba:d3d3/d7d7/cfcf/f500

! Font prefferenes
URxvt*font: xft:DejaVu Sans Mono:pixelsize=16, xft:Inconsolata for Powerline
URxvt*boldFont: xft:DejaVu Sans Mono:pixelsize=16:weight=bold
URxvt*letterSpace: -1

! Larger history limit
URxvt*saveLines: 0

! Perl extensions
URxvt*perl-ext-common: default,matcher,resize-font

! Urls config 
URxvt*url-launcher: /usr/lib/firefox/firefox
URxvt*matcher.button: C1
! URxvt*matcher.rend.0: Uline Bold fg5
URxvt*matcher.rend.0: Uline Bold
URxvt*url-select.underline: true

! Change font size on Control-Plus/Minus
URxvt*keysym.Control-0x2b: perl:resize-font:increase
URxvt*keysym.Control-0x2d: perl:resize-font:decrease

! Copy/Paste
URxvt*iso14755: false
URxvt*iso14755_52: false 
URxvt*keysym.Shift-Control-V: eval:paste_clipboard
URxvt*keysym.Shift-Control-C: eval:selection_to_clipboard

! Yeah, I am one of those, who use these keys in Vim :-(
URxvt*keysym.Home:          \033[1~
URxvt*keysym.End:           \033[4~
URxvt*keysym.Control-Up:    \033[1;5A
URxvt*keysym.Control-Down:  \033[1;5B
URxvt*keysym.Control-Left:  \033[1;5D
URxvt*keysym.Control-Right: \033[1;5C

! Tango color theme
! black dark/light
URxvt*color0: #2e3436
URxvt*color8: #6e706b
! red dark/light
URxvt*color1: #cc0000
URxvt*color9: #ef2929
! green dark/light
URxvt*color2: #4e9a06
URxvt*color10: #8ae234
! yellow dark/light
URxvt*color3: #edd400
URxvt*color11: #fce94f
! blue dark/light
URxvt*color4: #3465a4
URxvt*color12: #729fcf
! magenta dark/light
URxvt*color5: #92659a
URxvt*color13: #c19fbe
! cyan dark/light
URxvt*color6: #07c7ca
URxvt*color14: #63e9e9
! white dark/light
URxvt*color7: #d3d7cf
URxvt*color15: #eeeeec
